# .env.example

# [REQUIRED] Kanana AI API Key (Get it from Kakao Cloud Console)
KANANA_API_KEY=your_api_key_here

# [REQUIRED] Kanana API Base Endpoint
# Example: https://kanana-o.a2s-endpoint.kr-central-2.kakaocloud.com
KANANA_ENDPOINT=https://your-endpoint-url

# [OPTIONAL] App Environment (development, production)
NODE_ENV=development