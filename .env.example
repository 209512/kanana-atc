# .env.example
# AI Model Configuration
# NOTE: Recommend client-side input via UI instead of Vercel env hardcoding
# ONLY for local development and testing
KANANA_API_KEY=your_kakao_api_key_here
KANANA_ENDPOINT=https://your-kanana-o-endpoint/v1/
KANANA_MODEL=kanana-o

# Google Gemini API 인증 키 (디지털 트윈 모드용)
GEMINI_API_KEY=your_google_gemini_api_key_here

# OpenAI 및 Anthropic (옵션)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------
# [OPTIONAL] Security & Redis Configuration
# ---------------------------------------------------------
# JWT signature key (Currently unused in edge functions)
JWT_SECRET=your_jwt_secret_key_here

# ---------------------------------------------------------
# [OPTIONAL] Redis Integration (Rate Limit, IP Ban)
# ---------------------------------------------------------
# Upstash Redis for global rate limit & blacklist (Fallback: In-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Blacklisted IP array (comma separated)
BLACKLISTED_IPS=

# Audio Mode Configuration
# true: Kanana-O Stream | false: Web Speech API (Lite)
VITE_USE_KANANA_AUDIO=false

# ---------------------------------------------------------
# [OPTIONAL] Simulation & Extended Configs
# ---------------------------------------------------------
# true: Enable MSW (Mock Service Worker) for zero-infra simulation
VITE_USE_MSW=true

# Base API URL (Optional on Vercel)
VITE_API_BASE_URL=

# CORS Allowed Origins (comma separated)
VITE_ALLOWED_ORIGINS=

# Agent load & latency thresholds
VITE_LOAD_THRESHOLD=70
VITE_LATENCY_THRESHOLD=100

# Initial AI call quota limit
VITE_AI_QUOTA=20

# API configurations (ms)
VITE_API_TIMEOUT=60000
VITE_API_RETRIES=0
VITE_API_BACKOFF=300

# Risk level boundaries
VITE_LEVEL_NORMAL=30
VITE_LEVEL_CAUTION=70
VITE_EMERGENCY_LEVEL=85
VITE_LEVEL_EMERGENCY=95

# 3D Radar drone rotation speed multipliers
VITE_DRONE_ROTATION_SPEED=0.02
VITE_DRONE_ROTATION_FORCED=0.08
VITE_DRONE_ROTATION_AI=0.15

# Agent detail popup delay (ms)
VITE_DETAIL_POPUP_DELAY_MS=1500