# .env.example

# ==========================================
# KANANA ATC - ZERO CONFIG DEPLOYMENT GUIDE
# ==========================================
# NOTE: This project is optimized for Vercel Free Tier with ZERO environment variables.
# All variables below are OPTIONAL and used only for local development or custom setups.

# 1. Kakao Kanana API Settings (Optional)
# If empty: Uses API key entered via UI and default Kakao Cloud endpoint.
KANANA_API_KEY=
KANANA_ENDPOINT=

# 2. Vercel Free Tier & Audio Modality Control (Optional)
# If empty: Uses PCM audio locally. Fallbacks to TTS on Vercel to bypass 5MB payload limit.
VITE_USE_KANANA_AUDIO=true

# 3. MSW Simulation (Optional)
# If empty: Forced to true in main.tsx.
VITE_USE_MSW=true

# 4. Frontend Local Encryption Secret (Optional)
# If empty: Automatically generates a random AES-GCM secret in the browser.
VITE_SECURE_KEY=

# 5. Backend Security JWT Secret (Optional)
# If empty: Generates an ephemeral secret on each serverless cold start.
JWT_SECRET=

# 6. Upstash Redis / Vercel KV for Rate Limiting & Async Queue (Optional)
# If empty: Fallbacks to local memory cache.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# [OPTIONAL] System Configs
VITE_API_BASE_URL=
WTTR_URL=https://wttr.in/{region}?format=j1
WTTR_API_TIMEOUT=3000
KANANA_API_TIMEOUT=300000
MAX_PAYLOAD_LENGTH=20000
MAX_DAILY_QUOTA=20
MAX_REQUESTS=20
VITE_ALLOWED_ORIGINS=
VITE_LOAD_THRESHOLD=70
VITE_LATENCY_THRESHOLD=100
VITE_API_TIMEOUT=60000
VITE_API_RETRIES=0
VITE_API_BACKOFF=300
VITE_LEVEL_NORMAL=30
VITE_LEVEL_CAUTION=70
VITE_EMERGENCY_LEVEL=85
VITE_LEVEL_EMERGENCY=95
VITE_DRONE_ROTATION_SPEED=0.02
VITE_DRONE_ROTATION_FORCED=0.08
VITE_DRONE_ROTATION_AI=0.15
VITE_DETAIL_POPUP_DELAY_MS=1500